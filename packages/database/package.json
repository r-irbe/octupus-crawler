{
  "name": "@ipf/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./errors": "./src/errors.ts",
    "./connection/pool": "./src/connection/pool.ts",
    "./connection/s3-client": "./src/connection/s3-client.ts",
    "./repositories/crawl-url-repository": "./src/repositories/crawl-url-repository.ts",
    "./repositories/drizzle-crawl-url-repository": "./src/repositories/drizzle-crawl-url-repository.ts",
    "./repositories/event-publishing-crawl-url-repository": "./src/repositories/event-publishing-crawl-url-repository.ts",
    "./repositories/page-content-repository": "./src/repositories/page-content-repository.ts",
    "./repositories/s3-page-content-repository": "./src/repositories/s3-page-content-repository.ts",
    "./repositories/crawl-session-repository": "./src/repositories/crawl-session-repository.ts",
    "./connection/drizzle": "./src/connection/drizzle.ts",
    "./connection/circuit-breaker": "./src/connection/circuit-breaker.ts",
    "./connection/shutdown": "./src/connection/shutdown.ts",
    "./schema/crawl-urls": "./src/schema/crawl-urls.ts",
    "./schema/crawl-links": "./src/schema/crawl-links.ts",
    "./schema/crawl-sessions": "./src/schema/crawl-sessions.ts",
    "./types": "./src/types.ts",
    "./prisma": "./src/prisma-client.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ignore-pattern src/generated/",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "clean": "rm -rf dist src/generated .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@prisma/client": "^6.19.3",
    "cockatiel": "^3.2.1",
    "drizzle-orm": "^0.45.2",
    "neverthrow": "^8.2.0",
    "pg": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ipf/eslint-config": "workspace:*",
    "@ipf/testing": "workspace:*",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "eslint": "^10.2.0",
    "prisma": "^6.19.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
