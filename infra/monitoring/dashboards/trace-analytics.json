{
  "title": "Trace Analytics",
  "uid": "trace-analytics",
  "panels": [
    {
      "title": "Request Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(fetch_duration_seconds_bucket[1m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": { "type": "log", "log": 2 }
          }
        }
      },
      "options": {
        "calculate": false,
        "color": { "scheme": "Spectral", "reverse": true },
        "yAxis": { "unit": "s" }
      }
    },
    {
      "title": "Error Rate by Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (error_kind) (rate(fetches_total{status=\"error\"}[2m]))",
          "legendFormat": "{{error_kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Slowest Operations (P99)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.99, sum(rate(fetch_duration_seconds_bucket[5m])) by (le)))",
          "legendFormat": "fetch-pipeline"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal" }
    },
    {
      "title": "Trace Search — Recent Errors",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "jaeger", "uid": "jaeger" },
      "targets": [
        {
          "queryType": "search",
          "service": "ipf-crawler",
          "tags": "error=true",
          "limit": 20
        }
      ]
    },
    {
      "title": "Latency Distribution (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(fetch_duration_seconds_bucket[3m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(fetch_duration_seconds_bucket[3m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(fetch_duration_seconds_bucket[3m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "schemaVersion": 39
}
