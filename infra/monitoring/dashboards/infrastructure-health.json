{
  "title": "Infrastructure Health",
  "uid": "infrastructure-health",
  "panels": [
    {
      "title": "CPU Usage by Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"ipf\"}[2m]))",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Memory Usage by Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"ipf\"})",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 20, "thresholdsStyle": { "mode": "line" } },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 536870912 }
            ]
          }
        }
      }
    },
    {
      "title": "Redis/Dragonfly Connections",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "dragonfly_connected_clients", "legendFormat": "Connected clients" },
        { "expr": "dragonfly_blocked_clients", "legendFormat": "Blocked clients" }
      ]
    },
    {
      "title": "Redis Memory",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "dragonfly_used_memory_bytes" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 268435456 },
              { "color": "red", "value": 536870912 }
            ]
          }
        }
      }
    },
    {
      "title": "PostgreSQL Active Connections",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pg_stat_activity_count{state=\"active\"}" }
      ]
    },
    {
      "title": "ArgoCD Sync Status",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "argocd_app_info{sync_status=\"Synced\"}", "legendFormat": "Synced" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "SYNCED", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "OUT OF SYNC", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "ArgoCD Health Status",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "argocd_app_info{health_status=\"Healthy\"}", "legendFormat": "Health" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "HEALTHY", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DEGRADED", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "ArgoCD Sync History",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(argocd_app_sync_total[5m])", "legendFormat": "Syncs" }
      ]
    },
    {
      "title": "Network I/O (Receive)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_network_receive_bytes_total{namespace=\"ipf\"}[2m]))",
          "legendFormat": "{{pod}} rx"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "Network I/O (Transmit)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_network_transmit_bytes_total{namespace=\"ipf\"}[2m]))",
          "legendFormat": "{{pod}} tx"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "schemaVersion": 39
}
