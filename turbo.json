{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "src/generated/**"]
    },
    "typecheck": {
      "dependsOn": ["build", "^build"]
    },
    "lint": {
      "dependsOn": ["build", "^build"]
    },
    "test": {
      "dependsOn": ["build", "^build"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:property": {
      "dependsOn": ["^build"]
    },
    "test:alerts": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
