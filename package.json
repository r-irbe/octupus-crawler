{
  "name": "@ipf/root",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "verify:guards": "./scripts/verify-guard-chain.sh",
    "verify:gates": "./scripts/verify-gate-compliance.sh",
    "verify:session": "./scripts/verify-session-compliance.sh",
    "verify:all": "./scripts/verify-guard-chain.sh && ./scripts/verify-gate-compliance.sh && ./scripts/verify-session-compliance.sh"
  },
  "devDependencies": {
    "turbo": "^2.8.0",
    "typescript": "^6.0.0"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/eslint-plugin>typescript": "^6.0.0",
      "@typescript-eslint/parser>typescript": "^6.0.0",
      "@typescript-eslint/typescript-estree>typescript": "^6.0.0"
    },
    "onlyBuiltDependencies": [
      "unrs-resolver",
      "protobufjs"
    ]
  }
}
