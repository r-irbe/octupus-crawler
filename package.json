{
  "name": "@ipf/root",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "prepare": "./scripts/setup-hooks.sh",
    "verify:guards": "./scripts/verify-guard-chain.sh",
    "verify:gates": "./scripts/verify-gate-compliance.sh",
    "verify:specs": "./scripts/verify-spec-update.sh",
    "verify:session": "./scripts/verify-session-compliance.sh",
    "verify:all": "./scripts/verify-guard-chain.sh && ./scripts/verify-gate-compliance.sh && ./scripts/verify-spec-update.sh && ./scripts/verify-session-compliance.sh",
    "test:alerts": "promtool check rules infra/prometheus/alert-rules.yml && promtool test rules infra/prometheus/alert-rules-fetch.test.yml infra/prometheus/alert-rules-ops.test.yml",
    "k8s:setup": "./scripts/setup-local.sh",
    "k8s:teardown": "./scripts/teardown-local.sh",
    "k8s:build": "./scripts/build-and-push.sh",
    "k8s:e2e": "cd packages/testing && pnpm vitest run --config vitest.e2e.config.ts",
    "k6:load": "k6 run packages/testing/src/load/throughput.k6.js --out json=packages/testing/test-results/k6-throughput.json",
    "k6:backpressure": "k6 run packages/testing/src/load/backpressure.k6.js --out json=packages/testing/test-results/k6-backpressure.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "typespec:compile": "tsp compile specs/",
    "typespec:lint": "spectral lint specs/generated/openapi.v1.yaml --ruleset specs/.spectral.yaml"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@stoplight/spectral-cli": "^6.15.1",
    "@typespec/compiler": "^1.11.0",
    "@typespec/http": "^1.11.0",
    "@typespec/openapi": "^1.11.0",
    "@typespec/openapi3": "^1.11.0",
    "@typespec/rest": "^0.81.0",
    "@typespec/versioning": "^0.81.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/eslint-plugin>typescript": "^6.0.0",
      "@typescript-eslint/parser>typescript": "^6.0.0",
      "@typescript-eslint/typescript-estree>typescript": "^6.0.0"
    },
    "onlyBuiltDependencies": [
      "-",
      "'",
      "[",
      "]",
      "@",
      "*",
      "a",
      "b",
      "c",
      "e",
      "f",
      "g",
      "j",
      "k",
      "m",
      "o",
      "p",
      "r",
      "s",
      "t",
      "u",
      "x"
    ]
  }
}
